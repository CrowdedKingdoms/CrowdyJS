{
  "name": "@crowdedkingdomstudios/crowdyjs",
  "version": "1.0.1",
  "description": "Client SDK for Crowded Kingdoms GraphQL API with UDP proxy support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "crowded-kingdoms",
    "graphql",
    "udp-proxy",
    "multiplayer",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}

